# Database
DATABASE_URL=postgresql+asyncpg://user:password@GCP_IP:5433/linkdbot_rag

# Docker PostgreSQL (docker-compose.yml에서 사용)
POSTGRES_DB=linkdbot_rag
POSTGRES_USER=linkdbot
POSTGRES_PASSWORD=

# OpenAI
OPENAI_API_KEY=sk-...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/webhook/telegram
TELEGRAM_TEST_ID=123456789

# Notion OAuth
NOTION_CLIENT_ID=...
NOTION_CLIENT_SECRET=...
NOTION_REDIRECT_URI=https://your-domain.com/api/v1/auth/notion/callback

# Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=...
