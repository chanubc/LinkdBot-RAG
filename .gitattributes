# 모든 텍스트 파일은 LF로 통일
* text=auto eol=lf

# Python
*.py text eol=lf

# Config / Docs
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.env text eol=lf
*.ini text eol=lf

# Binary — 변환 제외
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
