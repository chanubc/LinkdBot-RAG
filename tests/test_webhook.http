@base_url = http://localhost:8000
@telegram_id = {{$dotenv TELEGRAM_TEST_ID}}

### ──────────────────────────────────────────
### /start — Notion 미연동 유저
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000001,
  "message": {
    "message_id": 1,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/start"
  }
}

### ──────────────────────────────────────────
### /start — Notion 연동 완료 유저 (환영 메시지)
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000002,
  "message": {
    "message_id": 2,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "개발자" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/start"
  }
}

### ──────────────────────────────────────────
### URL 저장 — 링크 처리 파이프라인
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000003,
  "message": {
    "message_id": 3,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "https://news.hada.io/weekly/202607"
  }
}

### ──────────────────────────────────────────
### URL + 메모 함께 전송
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000004,
  "message": {
    "message_id": 4,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "https://github.com/tiangolo/fastapi 나중에 꼭 다시 읽기"
  }
}

### ──────────────────────────────────────────
### /memo — 메모 저장
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000005,
  "message": {
    "message_id": 5,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/memo 오늘 배운 파이썬 asyncio 정리"
  }
}

### ──────────────────────────────────────────
### /memo — 내용 없음 (에러 안내 메시지 확인)
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000006,
  "message": {
    "message_id": 6,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/memo"
  }
}

### ──────────────────────────────────────────
### /search — 키워드 검색
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000007,
  "message": {
    "message_id": 7,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/search 파이썬"
  }
}

### ──────────────────────────────────────────
### /search — 검색어 없음 (에러 안내 메시지 확인)
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000008,
  "message": {
    "message_id": 8,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/search"
  }
}

### ──────────────────────────────────────────
### 일반 텍스트 — 자동 시맨틱 검색
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000009,
  "message": {
    "message_id": 9,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "머신러닝 관련 저장한 것 있어?"
  }
}

### ──────────────────────────────────────────
### callback_query — 도움말 버튼 클릭
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000010,
  "callback_query": {
    "id": "callback-001",
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "data": "help"
  }
}

### ──────────────────────────────────────────
### /dashboard — 대시보드 링크 버튼 발송
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/webhook/telegram
Content-Type: application/json

{
  "update_id": 100000011,
  "message": {
    "message_id": 11,
    "from": { "id": {{telegram_id}}, "is_bot": false, "first_name": "TestUser" },
    "chat": { "id": {{telegram_id}}, "type": "private" },
    "date": 1700000000,
    "text": "/dashboard"
  }
}

### ──────────────────────────────────────────
### REST Search API — GET /api/v1/search
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/search?telegram_id={{telegram_id}}&q=파이썬&top_k=5

### ══════════════════════════════════════════
### Phase 4: Dashboard API
### JWT 토큰 생성 방법:
###   python -c "from app.core.jwt import create_dashboard_token; print(create_dashboard_token(YOUR_TELEGRAM_ID))"
### 생성된 토큰을 아래 @jwt_token 변수에 붙여넣기
### ══════════════════════════════════════════

@jwt_token = {{$dotenv DASHBOARD_TEST_JWT}}

### ──────────────────────────────────────────
### /auth/me — JWT 검증 + 유저 정보 반환
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/auth/me
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /drift/me — TVD + 8주 시계열
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/drift/me
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /reactivation/me — 점수 랭킹 (관심사 자동 감지)
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/reactivation/me
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /reactivation/me?query= — 키워드 기반 재계산
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/reactivation/me?query=머신러닝
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /embeddings/me — PCA 2D 좌표
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/embeddings/me
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /links/me — 링크 목록 (전체)
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/links/me
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /links/me — 미열람 링크만, AI 카테고리 필터
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/links/me?is_read=false&category=AI&page=1&page_size=25
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /stats/me — 전체 통계 (읽음률, 카테고리 분포 등)
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/stats/me
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /search/me — 시맨틱 검색 (JWT 기반 IDOR 방지)
### ──────────────────────────────────────────
GET {{base_url}}/api/v1/dashboard/search/me?q=머신러닝&top_k=5
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /links/{id}/read — 읽음 처리 (IDOR: 본인 링크만)
### ──────────────────────────────────────────
PATCH {{base_url}}/api/v1/dashboard/links/1/read
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /links/{id} — 링크 삭제 (IDOR: 본인 링크만)
### ──────────────────────────────────────────
DELETE {{base_url}}/api/v1/dashboard/links/1
Authorization: Bearer {{jwt_token}}

### ──────────────────────────────────────────
### /report/trigger/me — 주간 브리핑 강제 실행
### ──────────────────────────────────────────
POST {{base_url}}/api/v1/dashboard/report/trigger/me
Authorization: Bearer {{jwt_token}}
